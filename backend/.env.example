# Copy to `.env` (do NOT commit `.env`)
# Choose ONE provider (Serper or Tavily) or set both.

# Serper (Google Serper)
SERPER_API_KEY=

# Tavily
TAVILY_API_KEY=

# Optional: GitHub API rate limit (public profile + repos)
GITHUB_TOKEN=

# Optional: guaranteed Critic block + rerank for demo rehearsal (pins a bad #1).
# APPLYSMART_DEMO_VETO=1
